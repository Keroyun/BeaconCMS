{
  "functions": {
    "index.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "install.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "sitemap.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(assets|uploads)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.php"
    },
    {
      "src": "/install",
      "dest": "/install.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
