# Deny PHP execution in uploads directory
<FilesMatch "\.(?:php|phtml|php3|php4|php5|php7|php8|phps)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Disable script execution
Options -ExecCGI
AddHandler cgi-script .php .phtml .php3 .php4 .php5 .php7 .php8 .phps

# Extra protection via mod_php
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>
